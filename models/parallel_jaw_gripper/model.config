<?xml version="1.0"?>
<model>
  <name>parallel_jaw_gripper</name>
  <version>1.0</version>
  <sdf version="1.10">model.sdf</sdf>
  <description>Simple 2-finger parallel-jaw gripper with prismatic finger joints driven by Gazebo joint position controllers. Gravity is disabled so the floating gripper can be teleported via /world/&lt;world&gt;/set_pose without falling.</description>
</model>
