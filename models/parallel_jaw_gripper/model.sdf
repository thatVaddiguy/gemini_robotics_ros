<?xml version="1.0"?>
<sdf version="1.10">
  <model name="parallel_jaw_gripper">
    <pose>0 0 0 0 0 0</pose>

    <link name="palm">
      <gravity>false</gravity>
      <inertial>
        <mass>0.5</mass>
        <inertia><ixx>1e-3</ixx><iyy>1e-3</iyy><izz>1e-3</izz>
                 <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <collision name="c">
        <geometry><box><size>0.10 0.06 0.04</size></box></geometry>
      </collision>
      <visual name="v">
        <geometry><box><size>0.10 0.06 0.04</size></box></geometry>
        <material><ambient>0.20 0.20 0.70 1</ambient><diffuse>0.30 0.30 0.90 1</diffuse></material>
      </visual>
    </link>

    <link name="left_finger">
      <gravity>false</gravity>
      <pose>0 0.040 -0.05 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia><ixx>1e-5</ixx><iyy>1e-5</iyy><izz>1e-5</izz>
                 <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <collision name="c">
        <geometry><box><size>0.02 0.01 0.06</size></box></geometry>
      </collision>
      <visual name="v">
        <geometry><box><size>0.02 0.01 0.06</size></box></geometry>
        <material><ambient>0.10 0.10 0.10 1</ambient><diffuse>0.25 0.25 0.25 1</diffuse></material>
      </visual>
    </link>

    <link name="right_finger">
      <gravity>false</gravity>
      <pose>0 -0.040 -0.05 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia><ixx>1e-5</ixx><iyy>1e-5</iyy><izz>1e-5</izz>
                 <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <collision name="c">
        <geometry><box><size>0.02 0.01 0.06</size></box></geometry>
      </collision>
      <visual name="v">
        <geometry><box><size>0.02 0.01 0.06</size></box></geometry>
        <material><ambient>0.10 0.10 0.10 1</ambient><diffuse>0.25 0.25 0.25 1</diffuse></material>
      </visual>
    </link>

    <joint name="left_finger_joint" type="prismatic">
      <parent>palm</parent>
      <child>left_finger</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>0.0</lower><upper>0.05</upper><effort>50</effort><velocity>0.5</velocity></limit>
        <dynamics><damping>5.0</damping></dynamics>
      </axis>
    </joint>

    <joint name="right_finger_joint" type="prismatic">
      <parent>palm</parent>
      <child>right_finger</child>
      <axis>
        <xyz>0 -1 0</xyz>
        <limit><lower>0.0</lower><upper>0.05</upper><effort>50</effort><velocity>0.5</velocity></limit>
        <dynamics><damping>5.0</damping></dynamics>
      </axis>
    </joint>

    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>left_finger_joint</joint_name>
      <topic>/gripper/left_finger_cmd</topic>
      <p_gain>200</p_gain>
      <i_gain>0</i_gain>
      <d_gain>20</d_gain>
    </plugin>

    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>right_finger_joint</joint_name>
      <topic>/gripper/right_finger_cmd</topic>
      <p_gain>200</p_gain>
      <i_gain>0</i_gain>
      <d_gain>20</d_gain>
    </plugin>
  </model>
</sdf>
